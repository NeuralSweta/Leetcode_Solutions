class Solution {
    public int[] twoSum(int[] nums, int target ){
       Arrays.sort(nums);
       int low=0, high= nums.length-1;
       while(low < high){
        if(nums[low]+nums[high]>target)high--;
        else if(nums[low]+nums[high]<target)low++;
        else return new int[]{ low, high};
       }
       return new int[]{-1,-1};
    }
}
